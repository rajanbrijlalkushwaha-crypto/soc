# ── Data path ─────────────────────────────────────────────────────────────────
# Set this to the absolute path of the data folder on your server
DATA_ROOT=/path/to/socforubunut/data

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=sysadmin
ADMIN_PASSWORD=sysadmin

# ── Access tokens (auto-updated by OAuth callback) ────────────────────────────
ACCESS_TOKEN=
ACCESS_TOKEN_2=
ACCESS_TOKEN_3=

# ── Upstox OAuth ──────────────────────────────────────────────────────────────
UPSTOX_APP_NAME_1=Slot1
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

UPSTOX_APP_NAME_2=Slot2
UPSTOX_API_KEY_2=
UPSTOX_API_SECRET_2=

UPSTOX_APP_NAME_3=Slot3
UPSTOX_API_KEY_3=
UPSTOX_API_SECRET_3=

UPSTOX_REDIRECT_URI=http://YOUR_DOMAIN_OR_IP/api/admin/upstox-auth/callback

# ── Email ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=your@email.com
UPSTOX_EMAIL_TIME=08:00
