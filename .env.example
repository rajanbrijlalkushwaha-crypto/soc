# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Session cookie domain ──────────────────────────────────────────────────────
# Leave blank when using IP address (e.g. 13.210.72.93)
# Set to .soc.ai.in when using a domain (covers beta.soc.ai.in, soc.ai.in, etc.)
# COOKIE_DOMAIN=.soc.ai.in

# ── Data paths (set absolute path for your server) ───────────────────────────
# Local dev:
DATA_ROOT=/Users/admin/Desktop/socforubunut/data
# Production Ubuntu:
# DATA_ROOT=/home/ubuntu/soc/data

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=sysadmin
ADMIN_PASSWORD=sysadmin

# ── Upstox OAuth ──────────────────────────────────────────────────────────────
UPSTOX_REDIRECT_URI=http://localhost:3000/api/admin/upstox-auth/callback

# ── Email ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=rajanbrijlalkushwaha@gmail.com
UPSTOX_EMAIL_TIME=08:00

# ── Access tokens (auto-updated by OAuth callback) ────────────────────────────
ACCESS_TOKEN=
ACCESS_TOKEN_2=
